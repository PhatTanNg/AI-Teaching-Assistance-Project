# Backend Environment Variables
# Copy this file to .env and fill in the actual values

# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/ai-teaching-app

# JWT Secret for authentication
JWT_SECRET=your-secret-key-here

# OpenAI API Key for transcript summarization
# This key is used by the summarization service to generate automatic summaries
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-api-key-here

# Google Cloud Credentials (for speech-to-text if using Google API)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/google-credentials.json

# Server port
PORT=5001

# Environment
NODE_ENV=development

# Frontend URL (for password reset links in emails)
FRONTEND_URL=http://localhost:5173

# SMTP Email (for forgot-password emails)
# Gmail example: use an App Password if you have 2FA enabled
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=AITA <your-email@gmail.com>
